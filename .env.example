# =========================================================
# DeepSeek API (OpenAI 兼容) —— 官方文档 https://api-docs.deepseek.com/zh-cn/
# 也兼容任何 OpenAI 协议的 endpoint，把下面三项改成对应供应商即可。
# =========================================================

# 必填：DeepSeek 控制台申请的 API Key
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-replace-me

# Base URL：DeepSeek 官方推荐写法（不带 /v1）。
# 若你切换到其它 OpenAI 兼容服务（OpenAI/Qwen/Moonshot/智谱…），改这一项即可。
OPENAI_BASE_URL=https://api.deepseek.com

# 与 DEEPSEEK_API_KEY 二选一；OPENAI_API_KEY 优先生效。
# 当你既用 OpenAI 又用 DeepSeek 时建议保留 DEEPSEEK_API_KEY 一项即可。
# OPENAI_API_KEY=sk-...

# =========================================================
# 模型选择
# - deepseek-v4-flash  : 默认，低成本，已足够覆盖 SUT / UserSim
# - deepseek-v4-pro    : 高准确，推荐用于 Judge（语义判定更稳）
# 旧名 deepseek-chat / deepseek-reasoner 将于 2026/07/24 弃用，仍可用但不推荐。
# =========================================================
SUT_MODEL=deepseek-v4-flash
USER_SIM_MODEL=deepseek-v4-flash
# 默认 flash 走全流程（成本最低）；如需 Judge 更稳，改 deepseek-v4-pro 即可
JUDGE_MODEL=deepseek-v4-flash

# 可选：开启 v4-pro 的 thinking（推理）模式，提高 Judge 一致性
# 由 configs/default.yaml 的 judge.thinking 控制，默认关闭以省成本
# DEEPSEEK_REASONING_EFFORT=high

LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3
